stateDiagram-v2
    [*] --> Idle : power on

    Idle --> Authenticating : login attempt
    Idle --> [*] : power off

    state Authenticating {
        [*] --> CheckingCreds
        CheckingCreds --> MFA : ok
        CheckingCreds --> AuthFailed : bad password
        MFA --> AuthFailed : bad code
        MFA --> [*] : code ok
        AuthFailed --> [*]
        --
        [*] --> AuditPending
        AuditPending --> AuditLogged : record attempt
    }

    Authenticating --> Active : success
    Authenticating --> Locked : too many failures

    state fork_session <<fork>>
    state join_session <<join>>

    Active --> fork_session : begin session
    fork_session --> Logging
    fork_session --> Auditing
    Logging --> join_session
    Auditing --> join_session
    join_session --> Active : session ready

    Active --> Idle : logout
    Locked --> Idle : admin unlock

    state Resumable {
        [*] --> [H]
        [H] --> Working
        Working --> Paused : pause
        Paused --> [H*] : resume
    }

    Active --> Resumable
    Resumable --> Active : done

    note right of Locked
        Locked after 5\nfailed attempts
    end note
