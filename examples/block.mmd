    end

    subgraph Cache["Cache Tier"]
        R1["Redis Primary"]:1 R2["Redis Replica"]:1
    end

    subgraph DB["Database Tier"]
        PG["Postgres Primary"]:2 PGR["Postgres Replica"]:2
    end

    subgraph Jobs["Background Jobs"]
        W1["Worker 1"]:1 W2["Worker 2"]:1 Q["Job Queue"]:2
    end

    Internet --> LB
    LB --> API1
    LB --> API2
