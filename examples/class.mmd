classDiagram
    direction TB
    namespace Core {
        class Entity {
            <<abstract>>
            +UUID id
            +DateTime createdAt
            +DateTime updatedAt
            +equals(other Entity) bool
            +hashCode() int
        }
        class Repository~T~ {
            <<interface>>
            +findById(id UUID) T?
            +findAll() List~T~
            +save(entity T) T
            +delete(id UUID) void
        }
    }
    namespace Domain {
        class User {
            +String email
            +String passwordHash
            -String salt
            +Role role
            +activate() void
            +deactivate() void
            +checkPassword(raw String) bool
        }
        class Order {
            +OrderStatus status
            +Money total
            +List~LineItem~ items
            +place() void
            +cancel() void
            +addItem(item LineItem) void
        }
        class LineItem {
            +Product product
            +int quantity
            +Money price
            +subtotal() Money
        }
        class Product {
            +String name
            +Money price
            +int stock
        }
    }
    class Role {
        <<enumeration>>
        ADMIN
        USER
        GUEST
    }

    Entity <|-- User
    Entity <|-- Order
    Entity <|-- Product
    Repository~User~ <|.. UserRepository
    Order "1" *-- "1..*" LineItem : contains
    LineItem "many" --> "1" Product : references
    User "1" --> "0..*" Order : places
    User --> Role : has
